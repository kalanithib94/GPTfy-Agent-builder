# Generate a long random string for production (e.g. openssl rand -base64 32)
SESSION_SECRET=

# Salesforce Connected App (Web Server flow) — keep CLIENT_SECRET only on Vercel, never in client code
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=

# Must match Connected App callback URL exactly, e.g. https://your-app.vercel.app/api/salesforce/callback
SALESFORCE_CALLBACK_URL=http://localhost:3000/api/salesforce/callback

# Optional: AI-generated Apex + prompts (otherwise template bundle with health_Check_Agent)
OPENAI_API_KEY=
# Optional override (default gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini
