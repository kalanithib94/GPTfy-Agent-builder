# Generate a long random string for production (e.g. openssl rand -base64 32)
SESSION_SECRET=

# --- Salesforce (same Connected App variable names as patient-management-frontend backend) ---
# patient backend/env.example: SALESFORCE_CLIENT_ID, SALESFORCE_CLIENT_SECRET (+ user vars in .env there).
# Here: same ID/SECRET; user/password/token are NOT in env — entered on /connect (or use browser OAuth).
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=

# Web Server OAuth redirect — must match Connected App callback URL exactly
# (patient app uses server-side env user; this app adds an explicit callback for Next.js routes)
SALESFORCE_CALLBACK_URL=http://localhost:3000/api/salesforce/callback
# Optional: set SALESFORCE_USE_PKCE=true if your External Client App requires PKCE on the authorize URL.
# Password grant on /connect uses CLIENT_ID + CLIENT_SECRET only. Enable "Allow OAuth Username-Password Flows" on the Connected App if your org allows it.

# Optional: shared OpenAI key for ALL users of this app (server-only; never exposed to the browser)
OPENAI_API_KEY=
# Optional override (default gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# Unlock /admin to save the key in Redis instead (optional). Use a long random string (16+ chars).
# GEN_ADMIN_SECRET=

# If you add Vercel Redis (Upstash), these are set automatically — then you can store OPENAI_API_KEY via /admin
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
