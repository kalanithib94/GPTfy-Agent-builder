{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "quoteId": {
      "type": "string",
      "maxLength": 18,
      "description": "Quote Id to update. Use this OR name."
    },
    "name": {
      "type": "string",
      "maxLength": 255,
      "description": "Quote name to find (if quoteId not provided)."
    },
    "SBQQ__Status__c": {
      "type": "string"
    },
    "SBQQ__Primary__c": {
      "type": "boolean"
    },
    "SBQQ__ExpirationDate__c": {
      "type": "string",
      "description": "YYYY-MM-DD."
    },
    "SBQQ__PriceBook__c": {
      "type": "string",
      "maxLength": 18
    }
  },
  "additionalProperties": false
}
