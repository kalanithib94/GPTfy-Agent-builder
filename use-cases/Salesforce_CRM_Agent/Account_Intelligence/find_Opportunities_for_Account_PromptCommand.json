{
  "type": "object",
  "required": [],
  "properties": {
    "accountName": {
      "type": "string",
      "maxLength": 255,
      "description": "Account name to find opportunities for. Use this OR accountId."
    },
    "accountId": {
      "type": "string",
      "maxLength": 18,
